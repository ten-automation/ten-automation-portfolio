# Copy this file to ".env" and fill in real values. ".env" is gitignored.
# Only PUBLIC_-prefixed vars are exposed to the browser (Astro convention).

# Production site URL — used for canonical URLs, the sitemap, robots.txt, and
# absolute OG/Twitter image URLs. Set this to your real domain in production.
# If you deploy to Vercel and leave it unset, the project's .vercel.app URL is
# used automatically (via VERCEL_PROJECT_PRODUCTION_URL). Locally it falls back
# to http://localhost:4321.
PUBLIC_SITE_URL=https://your-domain.com

# Google Drive API browser key for the Certifications gallery (OPTIONAL).
# Without it, a polished "being connected" empty state is shown and the site
# works fine. The key is safe to ship ONLY if restricted in Google Cloud to the
# Drive API + your site's HTTP referrers. See README "Certifications".
# PUBLIC_GOOGLE_DRIVE_API_KEY=your-restricted-browser-key
