---
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkflowStrip from "../components/WorkflowStrip.astro";
import ProjectCard from "../components/ProjectCard.astro";
import CtaPanel from "../components/CtaPanel.astro";
import { systems } from "../data/systems";
import { projects } from "../data/projects";

const countFor = (key: string) =>
  key === "all" ? projects.length : projects.filter((p) => p.cats.includes(key)).length;
---
<BaseLayout
  title="Automation Systems"
  description="A demo lab of automation systems: AI chatbots, onboarding flows, content workflows, and multi-industry systems built with n8n, Apps Script, and AI."
  active="systems"
>
  <!-- HERO -->
  <section class="sys-hero">
    <div class="dot-grid"></div>
    <div class="glow-blob sys-hero__glow-a"></div>
    <div class="glow-blob sys-hero__glow-b"></div>
    <div class="container sys-hero__inner">
      <div class="pill reveal"><span class="pill__dot"></span><span class="pill__label">{systems.eyebrow}</span></div>
      <h1 class="display sys-hero__title reveal" style="--reveal-delay:0.06s">
        {systems.title} <span class="gradient-text">{systems.titleHighlight}</span>
      </h1>
      <p class="lead sys-hero__intro reveal" style="--reveal-delay:0.12s">{systems.intro}</p>
      <div class="sys-hero__strip reveal" style="--reveal-delay:0.18s">
        <WorkflowStrip nodes={systems.strip} center />
      </div>
    </div>
  </section>

  <!-- FILTERS + GRID -->
  <section class="section section--alt-rev">
    <div class="container">
      <div class="filters" role="group" aria-label="Filter automation systems">
        {systems.filters.map((f) => (
          <button
            type="button"
            class:list={["filter", { "is-on": f.key === "all" }]}
            data-filter={f.key}
            aria-pressed={f.key === "all" ? "true" : "false"}
          >
            <span class="filter__dot"></span>{f.label}<span class="filter__count">{countFor(f.key)}</span>
          </button>
        ))}
      </div>

      <p class="filters__status">
        Showing <span class="filters__count" data-count>{projects.length}</span>
        <span data-word>systems</span> in <span class="filters__active" data-active>All</span>
      </p>

      <div class="sys-grid" data-grid>
        {projects.map((project, i) => <ProjectCard project={project} index={i} />)}
      </div>

      <p class="sys-empty" data-empty hidden>No systems match that filter yet.</p>
    </div>
  </section>

  <CtaPanel
    eyebrow={systems.cta.eyebrow}
    title={systems.cta.title}
    body={systems.cta.body}
    buttonLabel={systems.cta.button.label}
    buttonHref={systems.cta.button.href}
  />
</BaseLayout>

<style>
  .sys-hero { position: relative; overflow: hidden; padding: clamp(48px, 6.5vw, 84px) 0 clamp(34px, 4vw, 52px); }
  .sys-hero__glow-a { top: -180px; right: -120px; background: radial-gradient(circle, rgba(143, 226, 198, 0.32), transparent 62%); }
  .sys-hero__glow-b { bottom: -260px; left: -160px; background: radial-gradient(circle, rgba(157, 180, 245, 0.3), transparent 62%); }
  .sys-hero__inner { position: relative; z-index: 2; max-width: 980px; margin-inline: auto; text-align: center; display: flex; flex-direction: column; align-items: center; }
  .sys-hero__title { margin-top: clamp(22px, 2.6vw, 30px); font-size: clamp(30px, 5vw, 58px); line-height: 1.06; }
  .sys-hero__intro { margin-top: clamp(18px, 2vw, 26px); max-width: 62ch; }
  .sys-hero__strip { margin-top: clamp(28px, 3.4vw, 40px); width: 100%; max-width: 860px; }

  .filters { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: clamp(20px, 2.4vw, 28px); }
  .filter {
    cursor: pointer; display: inline-flex; align-items: center; gap: 8px;
    background: var(--surface); color: var(--body-alt); font-weight: 600; font-size: 13.5px;
    padding: 10px 16px; border-radius: var(--radius-pill);
    border: 1.5px solid var(--card-border-strong); box-shadow: var(--shadow-card);
    transition: transform 0.25s var(--ease), border-color 0.25s, background 0.25s, color 0.25s;
  }
  .filter:hover { transform: translateY(-2px); border-color: var(--card-border-hover); }
  .filter__dot { width: 7px; height: 7px; border-radius: 50%; background: var(--peri-ink); }
  .filter__count { font-size: 11.5px; font-weight: 700; color: var(--muted); background: var(--surface-3); border-radius: var(--radius-pill); min-width: 20px; text-align: center; padding: 1px 6px; }
  .filter.is-on { background: var(--grad-primary); color: #fff; border-color: transparent; box-shadow: 0 10px 24px rgba(88, 113, 230, 0.34); }
  .filter.is-on .filter__dot { background: #fff; box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.3); }
  .filter.is-on .filter__count { color: #fff; background: rgba(255, 255, 255, 0.22); }

  .filters__status { font-size: 13px; font-weight: 600; color: var(--muted); margin-bottom: 18px; }
  .filters__count { color: var(--ink); font-weight: 700; }
  .filters__active { color: var(--peri-ink); font-weight: 700; }

  .sys-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 24px; align-items: stretch; }
  /* card hide is handled by the global .is-hidden utility (cross-scope) */
  .sys-empty { text-align: center; color: var(--body-alt); font-size: 16px; padding: 40px 0; }

  @media (max-width: 420px) {
    .sys-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".filter");
  const cards = document.querySelectorAll<HTMLElement>("[data-grid] .pcard");
  const countEl = document.querySelector<HTMLElement>("[data-count]");
  const wordEl = document.querySelector<HTMLElement>("[data-word]");
  const activeEl = document.querySelector<HTMLElement>("[data-active]");
  const emptyEl = document.querySelector<HTMLElement>("[data-empty]");

  function apply(key: string, label: string) {
    let shown = 0;
    cards.forEach((card) => {
      const cats = (card.dataset.cats ?? "").split(" ");
      const match = key === "all" || cats.includes(key);
      card.classList.toggle("is-hidden", !match);
      if (match) shown++;
    });
    if (countEl) countEl.textContent = String(shown);
    if (wordEl) wordEl.textContent = shown === 1 ? "system" : "systems";
    if (activeEl) activeEl.textContent = label;
    if (emptyEl) emptyEl.hidden = shown !== 0;
  }

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      buttons.forEach((b) => {
        b.classList.remove("is-on");
        b.setAttribute("aria-pressed", "false");
      });
      btn.classList.add("is-on");
      btn.setAttribute("aria-pressed", "true");
      apply(btn.dataset.filter ?? "all", btn.textContent?.trim().replace(/\d+$/, "").trim() ?? "All");
    });
  });
</script>
