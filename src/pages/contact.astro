---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import { contact } from "../data/contact";
import { site } from "../data/site";
import { icons } from "../lib/icons";

const configured = Boolean(site.formEndpoint) && !site.formEndpoint.includes("your-form-id");
---
<BaseLayout
  title="Contact"
  description="Request an automation consultation. Tell Cristen Joy Dimaguila about your manual process and what you'd like to automate."
  active="contact"
>
  <section class="chero">
    <div class="dot-grid"></div>
    <div class="glow-blob chero__glow"></div>
    <div class="container chero__inner">
      <div class="section-head reveal">
        <span class="eyebrow">{contact.eyebrow}</span>
        <h1 class="display">{contact.title}</h1>
        <p class="lead" style="margin-top:14px">{contact.intro}</p>
      </div>

      <div class="contact">
        <!-- FORM -->
        <form
          class="cform reveal"
          id="contact-form"
          action={configured ? site.formEndpoint : "#"}
          method="POST"
          data-configured={String(configured)}
          data-email={site.email}
          novalidate
        >
          <h2 class="cform__heading">{contact.form.heading}</h2>

          <div class="cform__grid">
            {contact.form.fields.map((field) => (
              <div class:list={["cfield", { "cfield--full": field.full || field.type === "textarea" || field.type === "select" }]}>
                <label class="cfield__label" for={field.name}>
                  {field.label}{field.required && <span class="cfield__req" aria-hidden="true">*</span>}
                </label>
                {field.type === "textarea" ? (
                  <textarea id={field.name} name={field.name} rows="4" placeholder={field.placeholder} required={field.required} aria-required={field.required ? "true" : undefined}></textarea>
                ) : field.type === "select" ? (
                  <div class="cfield__select">
                    <select id={field.name} name={field.name} required={field.required} aria-required={field.required ? "true" : undefined}>
                      <option value="" disabled selected>Select an option</option>
                      {field.options?.map((opt) => <option value={opt}>{opt}</option>)}
                    </select>
                  </div>
                ) : (
                  <input id={field.name} name={field.name} type={field.type} placeholder={field.placeholder} required={field.required} aria-required={field.required ? "true" : undefined} />
                )}
              </div>
            ))}
          </div>

          <!-- honeypot for spam bots -->
          <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="cform__hp" aria-hidden="true" />
          <input type="hidden" name="_subject" value={`New automation inquiry — ${site.siteName}`} />

          <div class="cform__footer">
            <button type="submit" class="btn btn--primary cform__submit">
              <span>{contact.form.submitLabel}</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
            </button>
            <p class="cform__note">{contact.form.note}</p>
          </div>

          <p class="cform__status" id="form-status" role="status" aria-live="polite" hidden></p>
        </form>

        <!-- CHANNELS -->
        <aside class="channels reveal" style="--reveal-delay:0.08s" aria-label="Direct contact channels">
          <h2 class="channels__heading">Prefer to reach out directly?</h2>
          {contact.channels.map((ch) => (
            <a
              class:list={["channel", `accent-${ch.accent}`]}
              href={ch.href}
              target={ch.external ? "_blank" : undefined}
              rel={ch.external ? "noopener noreferrer" : undefined}
            >
              <span class="channel__icon"><Icon paths={icons[ch.icon]} size={20} /></span>
              <span class="channel__meta">
                <span class="channel__label">{ch.label}</span>
                <span class="channel__value">{ch.value}</span>
              </span>
              <svg class="channel__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
            </a>
          ))}
          <div class="channels__status"><span class="channels__dot"></span>{site.availability}</div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .chero { position: relative; overflow: hidden; padding: clamp(44px, 6vw, 80px) 0 clamp(56px, 7vw, 104px); }
  .chero__glow { top: -160px; right: -120px; background: radial-gradient(circle, rgba(143, 226, 198, 0.3), transparent 62%); }
  .chero__inner { position: relative; z-index: 2; }

  .contact { display: grid; grid-template-columns: 1.6fr 1fr; gap: clamp(24px, 3vw, 40px); align-items: start; }
  @media (max-width: 880px) { .contact { grid-template-columns: 1fr; } }

  .cform { background: #fff; border: 1px solid var(--card-border-strong); border-radius: 26px; padding: clamp(24px, 3vw, 40px); box-shadow: 0 24px 60px rgba(64, 90, 180, 0.1); }
  .cform__heading { font-size: clamp(20px, 2.2vw, 26px); margin-bottom: 22px; }
  .cform__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 540px) { .cform__grid { grid-template-columns: 1fr; } }
  .cfield { display: flex; flex-direction: column; gap: 7px; }
  .cfield--full { grid-column: 1 / -1; }
  .cfield__label { font-size: 13.5px; font-weight: 600; color: #2b3566; }
  .cfield__req { color: var(--lilac-ink); margin-left: 2px; }
  .cfield input, .cfield textarea, .cfield select {
    width: 100%; font-family: var(--font-body); font-size: 14.5px; color: var(--ink);
    background: #f8f9ff; border: 1.5px solid #e0e5f4; border-radius: 12px; padding: 13px 15px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }
  .cfield textarea { resize: vertical; min-height: 110px; }
  .cfield input::placeholder, .cfield textarea::placeholder { color: #a7afcf; }
  .cfield input:focus, .cfield textarea:focus, .cfield select:focus { outline: none; border-color: #9db4f5; background: #fff; box-shadow: 0 0 0 4px rgba(157, 180, 245, 0.22); }
  .cfield input[aria-invalid="true"], .cfield textarea[aria-invalid="true"], .cfield select[aria-invalid="true"] { border-color: #e08aa0; box-shadow: 0 0 0 4px rgba(224, 138, 160, 0.18); }
  .cfield__select { position: relative; }
  .cfield__select::after { content: ""; position: absolute; right: 16px; top: 50%; width: 8px; height: 8px; border-right: 2px solid #7c86b8; border-bottom: 2px solid #7c86b8; transform: translateY(-65%) rotate(45deg); pointer-events: none; }
  .cfield select { appearance: none; -webkit-appearance: none; cursor: pointer; padding-right: 38px; }

  .cform__hp { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  .cform__footer { display: flex; flex-wrap: wrap; align-items: center; gap: 16px; margin-top: 22px; }
  .cform__submit { flex: 0 0 auto; }
  .cform__note { flex: 1 1 240px; margin: 0; font-size: 12.5px; line-height: 1.5; color: var(--muted); }
  .cform__status { margin: 18px 0 0; padding: 14px 16px; border-radius: 12px; font-size: 14px; font-weight: 600; }
  .cform__status.is-success { background: var(--mint-bg); color: var(--benefit-ink); border: 1px solid var(--benefit-border); }
  .cform__status.is-error { background: #fdeef1; color: #b4445f; border: 1px solid #f3c7d2; }

  .channels { display: flex; flex-direction: column; gap: 12px; }
  .channels__heading { font-size: 17px; margin-bottom: 6px; }
  .channel { display: flex; align-items: center; gap: 14px; background: #fff; border: 1px solid var(--card-border-strong); border-radius: 16px; padding: 16px 18px; text-decoration: none; box-shadow: 0 12px 30px rgba(64, 90, 180, 0.07); transition: transform 0.3s var(--ease), box-shadow 0.3s, border-color 0.3s; }
  .channel:hover { transform: translateY(-3px); box-shadow: 0 18px 40px rgba(64, 90, 180, 0.14); border-color: var(--card-border-hover); }
  .channel__icon { width: 42px; height: 42px; border-radius: 12px; background: var(--accent-bg); color: var(--accent-ink); display: flex; align-items: center; justify-content: center; flex: 0 0 auto; box-shadow: 0 8px 18px var(--accent-glow); }
  .channel__meta { display: flex; flex-direction: column; flex: 1; min-width: 0; }
  .channel__label { font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); }
  .channel__value { font-size: 14.5px; font-weight: 600; color: var(--ink); overflow-wrap: anywhere; }
  .channel__arrow { width: 18px; height: 18px; color: var(--accent-ink); flex: 0 0 auto; }
  .channels__status { display: inline-flex; align-items: center; gap: 8px; margin-top: 8px; font-size: 12.5px; font-weight: 600; color: var(--mint-ink); }
  .channels__dot { width: 8px; height: 8px; border-radius: 50%; background: #2fae84; box-shadow: 0 0 0 4px rgba(47, 174, 132, 0.18); }
</style>

<script is:inline define:vars={{ successMessage: contact.form.successMessage }}>
  const form = document.getElementById("contact-form");
  const statusEl = document.getElementById("form-status");
  if (form && statusEl) {
    const configured = form.dataset.configured === "true";
    const email = form.dataset.email;

    const setStatus = (msg, ok) => {
      statusEl.textContent = msg;
      statusEl.hidden = false;
      statusEl.classList.toggle("is-success", ok);
      statusEl.classList.toggle("is-error", !ok);
    };

    const validate = () => {
      let firstInvalid = null;
      form.querySelectorAll("[required]").forEach((el) => {
        const empty = !String(el.value).trim();
        el.setAttribute("aria-invalid", empty ? "true" : "false");
        if (empty && !firstInvalid) firstInvalid = el;
      });
      const emailField = form.querySelector('[name="email"]');
      if (emailField && emailField.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailField.value)) {
        emailField.setAttribute("aria-invalid", "true");
        if (!firstInvalid) firstInvalid = emailField;
      }
      return firstInvalid;
    };

    const mailtoFallback = () => {
      const data = new FormData(form);
      const lines = [];
      for (const [key, value] of data.entries()) {
        if (key.startsWith("_") || key === "_gotcha" || !String(value).trim()) continue;
        const label = key.replace(/_/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
        lines.push(`${label}: ${value}`);
      }
      const subject = encodeURIComponent("Automation project inquiry");
      const body = encodeURIComponent(lines.join("\n"));
      window.location.href = `mailto:${email}?subject=${subject}&body=${body}`;
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (form.querySelector('[name="_gotcha"]').value) return; // bot
      const invalid = validate();
      if (invalid) {
        setStatus("Please fill in the required fields highlighted above.", false);
        invalid.focus();
        return;
      }

      if (!configured) {
        setStatus("Opening your email app so you can send this inquiry…", true);
        mailtoFallback();
        return;
      }

      const submitBtn = form.querySelector(".cform__submit");
      submitBtn.disabled = true;
      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
        });
        if (res.ok) {
          form.reset();
          setStatus(successMessage, true);
        } else {
          setStatus("Something went wrong sending the form. Please email me directly instead.", false);
          mailtoFallback();
        }
      } catch {
        setStatus("Network issue sending the form. Opening your email app instead…", false);
        mailtoFallback();
      } finally {
        submitBtn.disabled = false;
      }
    });
  }
</script>
