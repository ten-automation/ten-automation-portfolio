---
/**
 * Discovery process: three reassuring, connected steps that reveal one by one,
 * followed by a trust note about keeping human judgment in the loop.
 */
import type { Accent, IconPaths } from "../lib/types";
import Icon from "./Icon.astro";

interface Step {
  accent: Accent;
  icon: IconPaths;
  title: string;
  copy: string;
}
interface Props {
  id: string;
  eyebrow: string;
  title: string;
  intro: string;
  steps: Step[];
  trustNote: string;
}
const { id, eyebrow, title, intro, steps, trustNote } = Astro.props;
---
<section class="section section--alt proc" id={id}>
  <div class="container">
    <div class="section-head section-head--center section-head--wide reveal">
      <span class="eyebrow eyebrow--accent">{eyebrow}</span>
      <h2 class="display">{title}</h2>
      <p class="lead" style="margin-top:14px">{intro}</p>
    </div>

    <ol class="proc__steps">
      {steps.map((step, i) => (
        <li class:list={["procstep", `accent-${step.accent}`, "reveal"]} style={`--reveal-delay:${(i * 0.12).toFixed(2)}s`}>
          <span class="procstep__num">{String(i + 1).padStart(2, "0")}</span>
          <span class="procstep__icon"><Icon paths={step.icon} size={22} /></span>
          <h3 class="procstep__title">{step.title}</h3>
          <p class="procstep__copy">{step.copy}</p>
          {i < steps.length - 1 && <span class="procstep__link" aria-hidden="true"></span>}
        </li>
      ))}
    </ol>

    <p class="proc__trust reveal">
      <span class="proc__trust-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><path d="M9 12l2 2 4-4" /></svg></span>
      <span>{trustNote}</span>
    </p>
  </div>
</section>

<style>
  .proc__steps {
    list-style: none; margin: 0 auto; padding: 0;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(18px, 2.4vw, 28px);
    max-width: 1080px;
  }
  .procstep {
    position: relative;
    display: flex; flex-direction: column; gap: 12px;
    background: linear-gradient(160deg, var(--lav-from), var(--surface));
    border: 1px solid var(--lav-border-soft);
    border-radius: 22px;
    padding: clamp(24px, 2.6vw, 32px);
    box-shadow: var(--shadow-card);
  }
  .procstep__num {
    font-family: var(--font-head); font-weight: 800; font-size: 14px;
    color: var(--accent-ink); letter-spacing: 0.05em;
  }
  .procstep__icon {
    width: 50px; height: 50px; border-radius: 14px;
    background: var(--accent-bg); color: var(--accent-ink);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 18px var(--accent-glow);
  }
  .procstep__title { font-size: clamp(18px, 1.9vw, 21px); line-height: 1.2; }
  .procstep__copy { font-size: 14.5px; line-height: 1.58; color: var(--body); }
  /* Connector dot between steps (desktop only). */
  .procstep__link {
    position: absolute; top: 50%; right: calc(-1 * clamp(18px, 2.4vw, 28px) / 2 - 6px);
    width: 12px; height: 12px; border-radius: 50%;
    background: var(--surface); border: 2px solid var(--accent-ink);
    transform: translate(50%, -50%); z-index: 2;
  }

  .proc__trust {
    display: flex; align-items: center; gap: 14px;
    max-width: 760px; margin: clamp(28px, 3vw, 40px) auto 0;
    background: var(--surface);
    border: 1px solid var(--lav-border-soft);
    border-left: 3px solid var(--lilac-ink);
    border-radius: 16px;
    padding: 18px 22px;
    font-size: 14.5px; line-height: 1.55; color: var(--body);
  }
  .proc__trust-icon {
    flex: 0 0 auto; width: 38px; height: 38px; border-radius: 11px;
    background: var(--lilac-bg); color: var(--lilac-ink);
    display: flex; align-items: center; justify-content: center;
  }
  .proc__trust-icon svg { width: 19px; height: 19px; }

  @media (max-width: 820px) {
    .proc__steps { grid-template-columns: 1fr; max-width: 480px; }
    .procstep__link { display: none; }
  }
</style>
