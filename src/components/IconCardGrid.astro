---
/** Responsive grid of accent icon cards (output types, industries, etc.). */
import type { IconCard } from "../lib/types";
import Icon from "./Icon.astro";

interface Props {
  items: IconCard[];
  min?: number;
}
const { items, min = 240 } = Astro.props;
---
<div class="icg" style={`--min:${min}px`}>
  {items.map((item, i) => (
    <div class:list={["icg__card", `accent-${item.accent}`, "reveal"]} style={`--reveal-delay:${(i * 0.04).toFixed(2)}s`}>
      <span class="icg__icon"><Icon paths={item.icon} size={20} /></span>
      <span class="icg__label">{item.label}</span>
    </div>
  ))}
</div>

<style>
  .icg { display: grid; grid-template-columns: repeat(auto-fill, minmax(var(--min), 1fr)); gap: 14px; }
  .icg__card {
    display: flex; align-items: center; gap: 14px;
    background: var(--surface); border: 1px solid var(--card-border); border-radius: 16px;
    padding: 16px 18px; box-shadow: var(--shadow-card);
    transition: transform 0.3s var(--ease), box-shadow 0.3s, border-color 0.3s;
  }
  .icg__card.is-visible:hover { transform: translateY(-3px); box-shadow: 0 18px 40px rgba(64, 90, 180, 0.14); border-color: var(--card-border-hover); }
  .icg__icon {
    width: 40px; height: 40px; border-radius: 11px; flex: 0 0 auto;
    background: var(--accent-bg); color: var(--accent-ink);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 18px var(--accent-glow);
  }
  .icg__label { font-weight: 600; font-size: 14.5px; line-height: 1.3; color: var(--ink); }
</style>
