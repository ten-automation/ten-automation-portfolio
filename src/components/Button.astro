---
/** Link styled as a button. Variants map to the design's button styles. */
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "ghost" | "light";
  /** Trailing arrow (→) or leading play (▶) glyph. */
  icon?: "arrow" | "play" | "none";
  class?: string;
}
const { href, variant = "primary", icon = "arrow", class: className } = Astro.props;
const isExternal = href.startsWith("http");
---
<a
  href={href}
  class:list={["btn", `btn--${variant}`, className]}
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "noopener noreferrer" : undefined}
>
  {icon === "play" && (
    <svg viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><polygon points="6 4 20 12 6 20 6 4" /></svg>
  )}
  <span><slot /></span>
  {icon === "arrow" && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
  )}
</a>
