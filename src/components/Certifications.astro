---
/**
 * Certifications — a custom, portfolio-styled gallery. Certificate images live
 * in a Google Drive folder; the browser lists them via the Drive API (using a
 * public, restricted key) and renders styled cards with titles cleaned from the
 * file names. Clicking a card opens an accessible larger preview modal.
 *
 * No Google Drive UI is shown to visitors (no folder iframe, toolbar, or
 * sign-in box). When `PUBLIC_GOOGLE_DRIVE_API_KEY` is not set, the ENTIRE
 * section is hidden (nothing renders) so visitors never see an unfinished
 * gallery. The moment the key (and public folder sharing) are in place, the
 * section appears automatically (see README).
 */
import { certifications } from "../data/site";

const folderId = certifications.driveFolderId;
const env = import.meta.env as Record<string, string | undefined>;
const apiKey = env.PUBLIC_GOOGLE_DRIVE_API_KEY ?? "";
const ready = certifications.enabled && Boolean(apiKey);
---
{ready && (
<section class="section section--alt certs" id={certifications.id}>
  <div class="container">
    <div class="section-head section-head--center section-head--wide reveal">
      <span class="eyebrow eyebrow--accent">{certifications.eyebrow}</span>
      <h2 class="display">{certifications.title}</h2>
      <p class="lead" style="margin-top:14px">{certifications.intro}</p>
    </div>

    <div class="certs__grid reveal" data-cert-grid data-folder={folderId} data-key={apiKey}>
      <div class="certs__state" data-cert-state>
        <span class="certs__spinner" aria-hidden="true"></span>
        <span data-cert-msg>Loading certifications…</span>
      </div>
    </div>
  </div>

  {/* Accessible preview modal (shared by all cards) */}
  <div class="certmodal" data-cert-modal hidden>
    <div class="certmodal__backdrop" data-cert-close></div>
    <div class="certmodal__dialog" role="dialog" aria-modal="true" aria-label="Certificate preview" tabindex="-1" data-cert-dialog>
      <button type="button" class="certmodal__close" data-cert-close aria-label="Close preview">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12" /></svg>
      </button>
      <div class="certmodal__imgwrap"><img class="certmodal__img" data-cert-modal-img src="" alt="" /></div>
      <p class="certmodal__title" data-cert-modal-title></p>
    </div>
  </div>
</section>
)}

<style>
  .certs__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: clamp(16px, 2vw, 24px);
    max-width: 1120px; margin-inline: auto;
  }

  .certs__state {
    grid-column: 1 / -1;
    display: flex; align-items: center; justify-content: center; gap: 12px;
    padding: clamp(36px, 6vw, 72px) 20px;
    font-size: 14.5px; color: var(--body); text-align: center;
  }
  .certs__spinner {
    width: 20px; height: 20px; flex: 0 0 auto; border-radius: 50%;
    border: 2.5px solid var(--lav-border); border-top-color: var(--lilac-ink);
    animation: cert-spin 0.8s linear infinite;
  }
  @keyframes cert-spin { to { transform: rotate(360deg); } }

  /* Cards (built by the script) */
  .certs__grid :global(.cert) {
    display: flex; flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--card-border-strong);
    border-radius: 18px; overflow: hidden;
    box-shadow: var(--shadow-card);
    cursor: pointer; text-align: left; font: inherit; color: inherit; padding: 0;
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease), border-color 0.3s ease;
    opacity: 0; transform: translateY(14px);
    animation: cert-in 0.5s var(--ease) forwards;
  }
  .certs__grid :global(.cert:hover) { transform: translateY(-5px); box-shadow: 0 26px 56px rgba(64, 90, 180, 0.18); border-color: var(--card-border-hover); }
  .certs__grid :global(.cert:focus-visible) { outline: 2.5px solid var(--peri-ink); outline-offset: 3px; }
  .certs__grid :global(.cert__img) {
    position: relative;
    aspect-ratio: 4 / 3; background: var(--surface-2);
    display: flex; align-items: center; justify-content: center; overflow: hidden;
    border-bottom: 1px solid var(--hairline);
  }
  .certs__grid :global(.cert__img img) { width: 100%; height: 100%; object-fit: contain; padding: 12px; }
  .certs__grid :global(.cert__doc) {
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px;
    color: var(--lilac-ink); font-size: 12px; font-weight: 600;
  }
  .certs__grid :global(.cert__doc svg) { width: 40px; height: 40px; }
  .certs__grid :global(.cert__zoom) {
    position: absolute; right: 10px; bottom: 10px;
    width: 32px; height: 32px; border-radius: 9px;
    background: color-mix(in srgb, var(--surface) 80%, transparent); color: var(--lav-ink);
    display: flex; align-items: center; justify-content: center;
    border: 1px solid var(--lav-border); opacity: 0; transition: opacity 0.25s ease;
  }
  .certs__grid :global(.cert:hover .cert__zoom), .certs__grid :global(.cert:focus-visible .cert__zoom) { opacity: 1; }
  .certs__grid :global(.cert__zoom svg) { width: 16px; height: 16px; }
  .certs__grid :global(.cert__name) {
    padding: 14px 16px; font-family: var(--font-head); font-weight: 700;
    font-size: 14.5px; line-height: 1.3; color: var(--ink);
  }
  @keyframes cert-in { to { opacity: 1; transform: none; } }

  /* Empty state */
  .certs__empty {
    max-width: 560px; margin: 0 auto;
    display: flex; flex-direction: column; align-items: center; text-align: center; gap: 16px;
    padding: clamp(40px, 6vw, 72px) clamp(20px, 3vw, 36px);
    background: linear-gradient(160deg, var(--lav-soft), var(--surface));
    border: 1px dashed var(--lav-border); border-radius: 22px;
  }
  .certs__empty-icon {
    width: 64px; height: 64px; border-radius: 18px;
    background: var(--lilac-bg); color: var(--lilac-ink);
    display: flex; align-items: center; justify-content: center;
  }
  .certs__empty-icon svg { width: 32px; height: 32px; }
  .certs__empty-title { font-family: var(--font-head); font-weight: 700; font-size: clamp(16px, 1.9vw, 20px); color: var(--ink); }

  /* Modal */
  .certmodal { position: fixed; inset: 0; z-index: 400; display: flex; align-items: center; justify-content: center; padding: clamp(16px, 4vw, 48px); }
  .certmodal[hidden] { display: none; }
  .certmodal__backdrop { position: absolute; inset: 0; background: rgba(17, 19, 40, 0.62); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); }
  .certmodal__dialog {
    position: relative; z-index: 1; max-width: min(920px, 94vw); max-height: 90vh;
    display: flex; flex-direction: column; gap: 12px;
    background: var(--surface); border: 1px solid var(--card-border-strong);
    border-radius: 22px; padding: clamp(14px, 2vw, 22px);
    box-shadow: var(--shadow-panel);
    animation: certmodal-in 0.32s var(--ease);
  }
  @keyframes certmodal-in { from { opacity: 0; transform: translateY(14px) scale(0.98); } to { opacity: 1; transform: none; } }
  .certmodal__close {
    position: absolute; top: -14px; right: -14px;
    width: 40px; height: 40px; border-radius: 50%;
    background: var(--surface); border: 1px solid var(--card-border-strong); color: var(--ink);
    display: flex; align-items: center; justify-content: center; cursor: pointer;
    box-shadow: var(--shadow-card); transition: transform 0.25s var(--ease);
  }
  .certmodal__close:hover { transform: scale(1.08); }
  .certmodal__close svg { width: 18px; height: 18px; }
  .certmodal__imgwrap { overflow: auto; border-radius: 14px; background: var(--surface-2); }
  .certmodal__img { display: block; width: 100%; height: auto; max-height: 74vh; object-fit: contain; margin: 0 auto; }
  .certmodal__title { text-align: center; font-family: var(--font-head); font-weight: 700; font-size: 16px; color: var(--ink); }

  @media (prefers-reduced-motion: reduce) {
    .certs__spinner { animation: none; }
    .certs__grid :global(.cert) { opacity: 1; transform: none; animation: none; }
    .certmodal__dialog { animation: none; }
  }
</style>

<script>
  // Lists certificate files from a public Google Drive folder via the Drive API
  // and renders custom cards. Titles are derived from file names. A shared,
  // accessible modal shows a larger preview.
  (() => {
    const grid = document.querySelector<HTMLElement>("[data-cert-grid]");
    const modal = document.querySelector<HTMLElement>("[data-cert-modal]");
    if (!modal) return;

    /* ----- Modal (accessible) ----- */
    const dialog = modal.querySelector<HTMLElement>("[data-cert-dialog]")!;
    const modalImg = modal.querySelector<HTMLImageElement>("[data-cert-modal-img]")!;
    const modalTitle = modal.querySelector<HTMLElement>("[data-cert-modal-title]")!;
    let lastFocused: HTMLElement | null = null;

    const openModal = (src: string, title: string) => {
      lastFocused = document.activeElement as HTMLElement;
      modalImg.src = src;
      modalImg.alt = title;
      modalTitle.textContent = title;
      modal.hidden = false;
      document.body.style.overflow = "hidden";
      dialog.focus();
    };
    const closeModal = () => {
      modal.hidden = true;
      modalImg.src = "";
      document.body.style.overflow = "";
      lastFocused?.focus();
    };
    modal.querySelectorAll("[data-cert-close]").forEach((el) => el.addEventListener("click", closeModal));
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal.hidden) closeModal();
    });

    if (!grid) return; // empty-state mode: modal exists but no cards to load
    const folderId = grid.dataset.folder ?? "";
    const key = grid.dataset.key ?? "";
    if (!folderId || !key) return;

    const stateMsg = grid.querySelector<HTMLElement>("[data-cert-msg]");
    const setMsg = (m: string) => { if (stateMsg) stateMsg.textContent = m; };

    const titleFromFile = (filename: string) =>
      filename.replace(/\.[^./\\]+$/, "").replace(/[_-]+/g, " ").replace(/\s+/g, " ").trim();
    const thumb = (id: string, w: number) => `https://drive.google.com/thumbnail?id=${id}&sz=w${w}`;

    const q = `'${folderId}' in parents and trashed = false and (mimeType contains 'image/' or mimeType = 'application/pdf')`;
    const url =
      "https://www.googleapis.com/drive/v3/files?" +
      new URLSearchParams({
        q,
        key,
        fields: "files(id,name,mimeType)",
        orderBy: "name_natural",
        pageSize: "200",
        supportsAllDrives: "true",
        includeItemsFromAllDrives: "true",
      }).toString();

    type DriveFile = { id: string; name: string; mimeType: string };

    fetch(url)
      .then((r) => (r.ok ? r.json() : Promise.reject(new Error("HTTP " + r.status))))
      .then((data: { files?: DriveFile[] }) => {
        const files = (data.files ?? []).filter(
          (f) => f.mimeType.startsWith("image/") || f.mimeType === "application/pdf",
        );
        if (!files.length) {
          setMsg("No certificates have been added yet.");
          return;
        }
        grid.innerHTML = "";
        files.forEach((f, i) => {
          const name = titleFromFile(f.name);
          const isPdf = f.mimeType === "application/pdf";

          const card = document.createElement("button");
          card.type = "button";
          card.className = "cert";
          card.style.animationDelay = `${Math.min(i, 14) * 0.05}s`;
          card.setAttribute("aria-label", `Open certificate: ${name}`);

          const imgWrap = document.createElement("span");
          imgWrap.className = "cert__img";

          const img = document.createElement("img");
          img.loading = "lazy";
          img.alt = name;
          img.src = thumb(f.id, 1000);
          img.addEventListener("error", () => {
            imgWrap.innerHTML =
              '<span class="cert__doc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>' +
              (isPdf ? "PDF document" : "Preview unavailable") +
              "</span>";
          });
          imgWrap.appendChild(img);

          const zoom = document.createElement("span");
          zoom.className = "cert__zoom";
          zoom.setAttribute("aria-hidden", "true");
          zoom.innerHTML =
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3M11 8v6M8 11h6"/></svg>';
          imgWrap.appendChild(zoom);

          const nm = document.createElement("span");
          nm.className = "cert__name";
          nm.textContent = name;

          card.appendChild(imgWrap);
          card.appendChild(nm);
          card.addEventListener("click", () => openModal(thumb(f.id, 1600), name));
          grid.appendChild(card);
        });
      })
      .catch(() => {
        setMsg("The certification gallery could not load right now.");
      });
  })();
</script>
