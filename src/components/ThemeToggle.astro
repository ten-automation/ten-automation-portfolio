---
/**
 * Accessible light/dark theme toggle. The initial theme is set before paint by
 * the inline script in BaseHead; this button flips it and persists the choice.
 * Deliberately understated so it never competes with the primary CTA.
 */
---
<button type="button" class="themetoggle" id="theme-toggle" aria-label="Switch theme" title="Switch theme">
  <svg class="themetoggle__sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
  </svg>
  <svg class="themetoggle__moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<style>
  .themetoggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex: 0 0 auto;
    border-radius: 12px;
    border: 1px solid var(--card-border-strong);
    background: var(--surface);
    color: var(--body-alt);
    cursor: pointer;
    box-shadow: 0 4px 12px rgba(91, 113, 170, 0.1);
    transition: transform 0.25s var(--ease), border-color 0.25s ease, color 0.25s ease, background 0.25s ease;
  }
  .themetoggle:hover { transform: translateY(-2px); border-color: var(--card-border-hover); color: var(--ink); }
  .themetoggle svg { width: 18px; height: 18px; }
  /* Show the icon for the theme you can switch TO. */
  .themetoggle__moon { display: none; }
  :root[data-theme="dark"] .themetoggle__sun { display: none; }
  :root[data-theme="dark"] .themetoggle__moon { display: block; }
</style>

<script>
  const btn = document.getElementById("theme-toggle");
  if (btn) {
    const sync = () => {
      const dark = document.documentElement.dataset.theme === "dark";
      btn.setAttribute("aria-label", dark ? "Switch to light theme" : "Switch to dark theme");
      btn.setAttribute("aria-pressed", String(dark));
    };
    sync();
    btn.addEventListener("click", () => {
      const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
      document.documentElement.dataset.theme = next;
      try { localStorage.setItem("theme", next); } catch (e) { /* ignore */ }
      sync();
    });
  }
</script>
