---
/**
 * Client pain-point cards: each pairs a relatable manual-work problem with the
 * automation outcome. Cards reveal one by one on scroll.
 */
import type { Accent, IconPaths } from "../lib/types";
import Icon from "./Icon.astro";

interface Card {
  accent: Accent;
  icon: IconPaths;
  pain: string;
  outcome: string;
}
interface Props {
  id: string;
  eyebrow: string;
  title: string;
  intro: string;
  cards: Card[];
}
const { id, eyebrow, title, intro, cards } = Astro.props;
---
<section class="section section--alt pain" id={id}>
  <div class="container">
    <div class="section-head section-head--center section-head--wide reveal">
      <span class="eyebrow eyebrow--accent">{eyebrow}</span>
      <h2 class="display">{title}</h2>
      <p class="lead" style="margin-top:14px">{intro}</p>
    </div>

    <div class="pain__grid">
      {cards.map((card, i) => (
        <article class:list={["paincard", `accent-${card.accent}`, "reveal"]} style={`--reveal-delay:${(i * 0.08).toFixed(2)}s`}>
          <span class="paincard__icon"><Icon paths={card.icon} size={22} /></span>
          <p class="paincard__pain">{card.pain}</p>
          <div class="paincard__outcome">
            <span class="paincard__arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
            </span>
            <span>{card.outcome}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .pain__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: clamp(16px, 2vw, 22px);
    max-width: 1120px;
    margin-inline: auto;
  }
  .paincard {
    display: flex;
    flex-direction: column;
    gap: 14px;
    background: var(--surface);
    border: 1px solid var(--card-border-strong);
    border-radius: 20px;
    padding: clamp(22px, 2.4vw, 28px);
    box-shadow: var(--shadow-card);
    transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease), border-color 0.35s var(--ease);
  }
  .paincard.is-visible:hover { transform: translateY(-5px); box-shadow: 0 26px 56px rgba(64, 90, 180, 0.16); border-color: var(--card-border-hover); }
  .paincard__icon {
    width: 46px; height: 46px; border-radius: 13px; flex: 0 0 auto;
    background: var(--accent-bg); color: var(--accent-ink);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 18px var(--accent-glow);
  }
  .paincard__pain { font-family: var(--font-head); font-weight: 600; font-size: clamp(16px, 1.6vw, 18px); line-height: 1.3; color: var(--ink); letter-spacing: -0.01em; }
  .paincard__outcome {
    display: flex; gap: 11px; align-items: flex-start;
    margin-top: auto;
    padding-top: 14px;
    border-top: 1px solid var(--hairline);
    font-size: 14.5px; line-height: 1.55; color: var(--body);
  }
  .paincard__arrow {
    flex: 0 0 auto; width: 26px; height: 26px; border-radius: 8px; margin-top: 1px;
    background: color-mix(in srgb, var(--accent-bg) 85%, transparent);
    color: var(--accent-ink);
    display: flex; align-items: center; justify-content: center;
  }
  .paincard__arrow svg { width: 14px; height: 14px; }
</style>
