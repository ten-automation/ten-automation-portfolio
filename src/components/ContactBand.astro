---
/**
 * Contact footer band: a final, direct way to reach out, anchored at #contact.
 * Pulls channels from site config so links stay editable in one place.
 */
import Icon from "./Icon.astro";
import { contactLinks } from "../data/site";
import { icons } from "../lib/icons";

interface Props {
  id: string;
  eyebrow: string;
  title: string;
  body: string;
}
const { id, eyebrow, title, body } = Astro.props;
---
<section class="section contactband" id={id}>
  <div class="container">
    <div class="contactband__panel reveal-scale">
      <div class="contactband__text">
        <span class="eyebrow eyebrow--accent">{eyebrow}</span>
        <h2 class="display contactband__title">{title}</h2>
        <p class="contactband__body">{body}</p>
      </div>
      <div class="contactband__links">
        {contactLinks.map((ch) => (
          <a
            class:list={["channel", `accent-${ch.accent}`]}
            href={ch.href}
            target={ch.external ? "_blank" : undefined}
            rel={ch.external ? "noopener noreferrer" : undefined}
          >
            <span class="channel__icon"><Icon paths={icons[ch.icon]} size={20} /></span>
            <span class="channel__meta">
              <span class="channel__label">{ch.label}</span>
              <span class="channel__value">{ch.value}</span>
            </span>
            <svg class="channel__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .contactband__panel {
    display: grid; grid-template-columns: 1fr 1fr; gap: clamp(24px, 3vw, 48px);
    align-items: center;
    background: linear-gradient(155deg, var(--lav-from), var(--surface));
    border: 1px solid var(--lav-border);
    border-radius: var(--radius-panel);
    padding: clamp(28px, 3.4vw, 52px);
    box-shadow: var(--shadow-raised);
  }
  .contactband__title { font-size: clamp(24px, 3vw, 38px); }
  .contactband__body { margin-top: 14px; font-size: clamp(15px, 1.4vw, 17px); line-height: 1.6; color: var(--body); max-width: 44ch; }

  .contactband__links { display: flex; flex-direction: column; gap: 12px; }
  .channel {
    display: flex; align-items: center; gap: 14px;
    background: var(--surface); border: 1px solid var(--card-border-strong);
    border-radius: 16px; padding: 15px 18px; text-decoration: none;
    box-shadow: var(--shadow-card);
    transition: transform 0.3s var(--ease), box-shadow 0.3s, border-color 0.3s;
  }
  .channel:hover { transform: translateY(-3px); box-shadow: 0 18px 40px rgba(64, 90, 180, 0.16); border-color: var(--card-border-hover); }
  .channel__icon {
    width: 42px; height: 42px; border-radius: 12px; flex: 0 0 auto;
    background: var(--accent-bg); color: var(--accent-ink);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 18px var(--accent-glow);
  }
  .channel__meta { display: flex; flex-direction: column; flex: 1; min-width: 0; }
  .channel__label { font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); }
  .channel__value { font-size: 14.5px; font-weight: 600; color: var(--ink); overflow-wrap: anywhere; }
  .channel__arrow { width: 18px; height: 18px; color: var(--accent-ink); flex: 0 0 auto; }

  @media (max-width: 820px) { .contactband__panel { grid-template-columns: 1fr; } }
</style>
