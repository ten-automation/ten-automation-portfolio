---
/**
 * Demo media section: one 16:9 video slot (real embed if `videoUrl` is set,
 * otherwise a labelled placeholder) + a grid of smaller dashed placeholders.
 * Placeholders are intentional — they await the client's real assets.
 */
import type { DemoMedia } from "../lib/types";
import Icon from "./Icon.astro";

interface Props {
  data: DemoMedia;
  title?: string;
}
const { data, title = "See it in action." } = Astro.props;
---
<section id="demo" class="section section--alt demo">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Demo media</span>
      <h2 class="display">{title}</h2>
      <p class="lead" style="margin-top:12px">{data.intro}</p>
    </div>

    {data.videoUrl ? (
      <div class="demo__video-embed reveal">
        <iframe src={data.videoUrl} title={data.videoLabel} loading="lazy" allow="accelerated-fullscreen; autoplay; encrypted-media; picture-in-picture" allowfullscreen></iframe>
      </div>
    ) : (
      <div class="demo__video reveal">
        <span class="demo__badge"><span class="demo__badge-dot"></span>Walkthrough coming soon</span>
        <span class="demo__play"><svg width="28" height="28" viewBox="0 0 24 24" fill="#fff" stroke="none" aria-hidden="true"><polygon points="6 4 20 12 6 20 6 4" /></svg></span>
        <div class="demo__caption">
          <div class="demo__caption-title">{data.videoLabel}</div>
          <div class="demo__hint">{data.videoHint}</div>
        </div>
      </div>
    )}

    <div class="demo__grid">
      {data.slots.map((slot) => (
        <div class:list={["demo__slot", `accent-${slot.accent}`]}>
          <span class="demo__slot-icon"><Icon paths={slot.icon} size={26} /></span>
          <div class="demo__caption">
            <div class="demo__caption-title">{slot.label}</div>
            <div class="demo__hint">[ add {slot.label.toLowerCase()} ]</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .demo { scroll-margin-top: 88px; }
  .demo__video, .demo__video-embed {
    position: relative; border-radius: 24px; overflow: hidden;
    aspect-ratio: 16 / 9; margin-bottom: 24px;
    box-shadow: 0 18px 44px rgba(64, 90, 180, 0.08);
  }
  .demo__video-embed iframe { width: 100%; height: 100%; border: 0; display: block; }
  .demo__video {
    border: 1.5px dashed #c4cef0;
    background: repeating-linear-gradient(135deg, #eef1fb, #eef1fb 14px, #f5f7fd 14px, #f5f7fd 28px);
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px;
  }
  .demo__badge {
    position: absolute; top: 18px; left: 18px;
    display: inline-flex; align-items: center; gap: 7px;
    background: #fff; border: 1px solid var(--card-border);
    border-radius: var(--radius-pill); padding: 6px 12px;
    font-size: 11.5px; font-weight: 700; letter-spacing: 0.04em; color: #7c86b8;
  }
  .demo__badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #f0b450; box-shadow: 0 0 0 3px rgba(240, 180, 80, 0.2); }
  .demo__play {
    width: 74px; height: 74px; border-radius: 50%;
    background: var(--grad-primary);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 16px 36px rgba(88, 113, 230, 0.4);
    animation: ring-pulse 2.4s ease-out infinite;
  }
  .demo__play svg { margin-left: 4px; }
  .demo__caption { text-align: center; }
  .demo__caption-title { font-family: var(--font-head); font-weight: 700; font-size: 16px; color: #2b3566; }
  .demo__hint { font-family: var(--font-body); font-size: 11.5px; letter-spacing: 0.04em; color: var(--muted); margin-top: 5px; }

  .demo__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px; }
  .demo__slot {
    position: relative; border-radius: 20px;
    border: 1.5px dashed #c4cef0;
    background: repeating-linear-gradient(135deg, #eef1fb, #eef1fb 12px, #f5f7fd 12px, #f5f7fd 24px);
    min-height: 230px;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px; padding: 24px;
    box-shadow: 0 14px 36px rgba(64, 90, 180, 0.07);
  }
  .demo__slot-icon {
    width: 54px; height: 54px; border-radius: 15px;
    background: var(--accent-bg); color: var(--accent-ink);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 10px 22px var(--accent-glow);
  }
  .demo__video-embed .demo__caption-title { color: #2b3566; }
</style>
