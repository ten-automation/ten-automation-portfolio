---
/**
 * Tools & stack rendered like an n8n workflow: the primary node (n8n) sits on
 * the left and branches out to the other tool nodes, with connector lines that
 * draw in one-by-one when the section scrolls into view. Stacks to a clean
 * vertical flow on mobile. Respects prefers-reduced-motion.
 */
import type { Accent, IconPaths } from "../lib/types";
import Icon from "./Icon.astro";

interface Tool {
  name: string;
  accent: Accent;
  icon: IconPaths;
  primary?: boolean;
  note?: string;
}
interface Props {
  items: Tool[];
}
const { items } = Astro.props;
const primary = items.find((t) => t.primary)!;
const rest = items.filter((t) => !t.primary);
---
<div class="tw" id="tw">
  <svg class="tw__wires" id="twWires" aria-hidden="true" preserveAspectRatio="none"></svg>

  <div class:list={["tw__hub", `accent-${primary.accent}`]} id="twHub">
    <span class="tw__hub-icon"><Icon paths={primary.icon} size={28} /></span>
    <span class="tw__hub-text">
      <span class="tw__hub-name">{primary.name}</span>
      <span class="tw__hub-note">{primary.note}</span>
    </span>
    <span class="tw__hub-pulse" aria-hidden="true"></span>
  </div>

  <div class="tw__nodes">
    {rest.map((t, i) => (
      <div class:list={["tw__node", `accent-${t.accent}`]} style={`--i:${i}`}>
        <span class="tw__node-icon"><Icon paths={t.icon} size={18} /></span>
        <span class="tw__node-name">{t.name}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .tw { position: relative; display: flex; align-items: center; gap: clamp(40px, 7vw, 110px); max-width: 980px; margin-inline: auto; }
  .tw__wires { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; overflow: visible; }

  .tw__hub {
    position: relative; z-index: 1; flex: 0 0 auto;
    display: flex; align-items: center; gap: 14px;
    background: linear-gradient(135deg, color-mix(in srgb, var(--accent-bg) 70%, #fff), #fff);
    border: 1.5px solid var(--accent-ink); border-radius: 18px;
    padding: 18px 26px 18px 20px;
    box-shadow: 0 18px 40px var(--accent-glow);
  }
  .tw__hub-icon { width: 52px; height: 52px; border-radius: 14px; background: var(--accent-ink); color: #fff; display: flex; align-items: center; justify-content: center; flex: 0 0 auto; box-shadow: 0 10px 22px var(--accent-glow); }
  .tw__hub-text { display: flex; flex-direction: column; line-height: 1.15; }
  .tw__hub-name { font-family: var(--font-head); font-weight: 800; font-size: 26px; letter-spacing: -0.02em; color: var(--ink); }
  .tw__hub-note { font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-ink); }
  .tw__hub-pulse { position: absolute; inset: 0; border-radius: 18px; box-shadow: 0 0 0 0 var(--accent-glow); animation: snode-pulse 2.8s ease-in-out infinite; }

  .tw__nodes { position: relative; z-index: 1; flex: 1 1 auto; display: grid; grid-template-columns: 1fr 1fr; gap: clamp(10px, 1.4vw, 16px); }
  .tw__node {
    display: flex; align-items: center; gap: 12px;
    background: #fff; border: 1px solid var(--card-border-strong); border-radius: 14px;
    padding: 13px 16px; box-shadow: 0 12px 28px rgba(64, 90, 180, 0.1);
    opacity: 0; transform: translateX(14px);
    transition: opacity 0.5s var(--ease), transform 0.5s var(--ease), box-shadow 0.3s var(--ease), border-color 0.3s;
    transition-delay: calc(var(--i) * 0.11s);
  }
  .tw.is-live .tw__node { opacity: 1; transform: none; }
  .tw__node:hover { box-shadow: 0 20px 42px rgba(64, 90, 180, 0.18), 0 0 0 3px var(--accent-glow); border-color: var(--accent-glow); transform: translateY(-3px); }
  .tw__node-icon { width: 36px; height: 36px; border-radius: 10px; background: var(--accent-bg); color: var(--accent-ink); display: flex; align-items: center; justify-content: center; flex: 0 0 auto; box-shadow: 0 6px 14px var(--accent-glow); }
  .tw__node-name { font-size: 15px; font-weight: 600; color: #2b3566; }

  @keyframes snode-pulse { 0%, 100% { box-shadow: 0 0 0 0 var(--accent-glow); } 50% { box-shadow: 0 0 0 10px rgba(88, 113, 230, 0); } }

  /* Mobile: clean vertical flow, CSS rail instead of the SVG fan. */
  @media (max-width: 760px) {
    .tw { flex-direction: column; gap: 0; align-items: stretch; }
    .tw__wires { display: none; }
    .tw__hub { align-self: center; margin-bottom: 8px; }
    .tw__nodes { grid-template-columns: 1fr; gap: 0; position: relative; }
    .tw__node { margin-top: 22px; transform: translateY(10px); }
    .tw.is-live .tw__node { transform: none; }
    .tw__node::before { content: ""; position: absolute; left: 50%; margin-top: -22px; width: 2px; height: 22px; background: linear-gradient(180deg, rgba(120, 134, 184, 0.5), rgba(120, 134, 184, 0.18)); transform: translateX(-50%); }
    .tw__node:first-child::before { background: linear-gradient(180deg, var(--peri-ink), rgba(120, 134, 184, 0.2)); }
  }

  @media (prefers-reduced-motion: reduce) {
    .tw__node { opacity: 1 !important; transform: none !important; transition: none !important; }
    .tw__hub-pulse { animation: none !important; }
  }
</style>

<script>
  (() => {
    const tw = document.getElementById("tw");
    const svg = document.getElementById("twWires") as SVGSVGElement | null;
    const hub = document.getElementById("twHub");
    if (!tw || !svg || !hub) return;

    const NS = "http://www.w3.org/2000/svg";
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isWide = () => window.matchMedia("(min-width: 761px)").matches;
    type Wire = { halo: SVGPathElement; main: SVGPathElement; len: number };
    let wires: Wire[] = [];
    let live = false;

    function build() {
      svg!.innerHTML = "";
      wires = [];
      if (!isWide()) return;
      const base = tw!.getBoundingClientRect();
      svg!.setAttribute("viewBox", `0 0 ${base.width} ${base.height}`);
      const defs = document.createElementNS(NS, "defs");
      defs.innerHTML =
        '<linearGradient id="twg" x1="0" y1="0" x2="1" y2="0"><stop offset="0" stop-color="#5871e6"/><stop offset="1" stop-color="#22b8e6"/></linearGradient>' +
        '<filter id="twf" x="-50%" y="-50%" width="200%" height="200%"><feDropShadow dx="0" dy="0" stdDeviation="2" flood-color="#5871e6" flood-opacity="0.4"/></filter>';
      svg!.appendChild(defs);
      const hr = hub!.getBoundingClientRect();
      const a = [hr.right - base.left, hr.top - base.top + hr.height / 2];
      tw!.querySelectorAll<HTMLElement>(".tw__node").forEach((node) => {
        const r = node.getBoundingClientRect();
        const b = [r.left - base.left, r.top - base.top + r.height / 2];
        // elbow: out from hub, then into the node — clean right-angle routing
        const midX = a[0] + (b[0] - a[0]) * 0.45;
        const d = `M ${a[0]} ${a[1]} L ${midX} ${a[1]} L ${midX} ${b[1]} L ${b[0]} ${b[1]}`;
        const len = Math.abs(midX - a[0]) + Math.abs(b[1] - a[1]) + Math.abs(b[0] - midX);
        const mk = (w: string, op: string, filter: boolean) => {
          const p = document.createElementNS(NS, "path");
          p.setAttribute("d", d); p.setAttribute("fill", "none"); p.setAttribute("stroke", "url(#twg)");
          p.setAttribute("stroke-width", w); p.setAttribute("stroke-linecap", "round"); p.setAttribute("stroke-linejoin", "round");
          p.setAttribute("opacity", op);
          if (filter) p.setAttribute("filter", "url(#twf)");
          p.style.strokeDasharray = String(len);
          p.style.strokeDashoffset = live || reduce ? "0" : String(len);
          svg!.appendChild(p);
          return p;
        };
        const halo = mk("6", "0.16", false);
        const main = mk("2.4", "1", true);
        wires.push({ halo, main, len });
      });
    }

    function play() {
      wires.forEach((w, i) => {
        const delay = i * 110 + 120;
        [w.halo, w.main].forEach((p) => {
          p.style.transition = `stroke-dashoffset 0.55s cubic-bezier(.16,1,.3,1) ${delay}ms`;
          requestAnimationFrame(() => { p.style.strokeDashoffset = "0"; });
        });
      });
    }

    build();
    if (reduce) {
      tw.classList.add("is-live");
    } else {
      const io = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((e) => {
            if (e.isIntersecting && !live) {
              live = true;
              tw.classList.add("is-live");
              build();
              play();
              obs.disconnect();
            }
          });
        },
        { threshold: 0.35 },
      );
      io.observe(tw);
    }

    let rt: number;
    window.addEventListener("resize", () => {
      window.clearTimeout(rt);
      rt = window.setTimeout(build, 150);
    }, { passive: true });
  })();
</script>
