---
/**
 * Tools & Stack: n8n as the prominent primary platform, with the rest of the
 * stack presented as a polished, gently auto-scrolling tool rail (a moving
 * banner of 3D-style icon tiles). Not a branched workflow diagram.
 * Reduced-motion users get a static, centered, wrapping row instead.
 */
import type { Accent, IconPaths } from "../lib/types";
import Icon from "./Icon.astro";

interface Tool {
  name: string;
  accent: Accent;
  icon: IconPaths;
  primary?: boolean;
  note?: string;
}
interface Props {
  eyebrow: string;
  title: string;
  intro: string;
  items: Tool[];
}
const { eyebrow, title, intro, items } = Astro.props;
const primary = items.find((t) => t.primary)!;
const others = items.filter((t) => !t.primary);
// Duplicate the set so the marquee can loop seamlessly (translateX -50%).
const railTools = [...others, ...others];
---
<section class="section tools">
  <div class="container">
    <div class="section-head section-head--center section-head--wide reveal">
      <span class="eyebrow eyebrow--accent">{eyebrow}</span>
      <h2 class="display">{title}</h2>
      <p class="lead" style="margin-top:14px">{intro}</p>
    </div>

    <div class:list={["tool-primary", `accent-${primary.accent}`, "reveal"]}>
      <span class="tool-primary__icon"><Icon paths={primary.icon} size={38} /></span>
      <div class="tool-primary__text">
        <span class="tool-primary__name">{primary.name}</span>
        <span class="tool-primary__note">{primary.note}</span>
        <p class="tool-primary__blurb">The primary platform where the workflows are designed, connected, tested, and run.</p>
      </div>
    </div>
  </div>

  <!-- Moving tool rail (full-bleed; clips inside the viewport) -->
  <div class="toolrail reveal" aria-label="Tools and integrations">
    <ul class="toolrail__track">
      {railTools.map((t, i) => (
        <li class:list={["tile", `accent-${t.accent}`]} aria-hidden={i >= others.length ? "true" : undefined}>
          <span class="tile__icon"><Icon paths={t.icon} size={22} /></span>
          <span class="tile__name">{t.name}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  /* ---- n8n primary platform ---- */
  .tool-primary {
    display: flex; align-items: center; gap: clamp(18px, 2.2vw, 28px);
    max-width: 720px; margin: 0 auto;
    padding: clamp(22px, 2.6vw, 34px) clamp(24px, 3vw, 40px);
    border-radius: 24px;
    border: 1.5px solid var(--accent-ink);
    background: linear-gradient(150deg, color-mix(in srgb, var(--accent-bg) 78%, var(--surface)), var(--surface));
    box-shadow: 0 22px 50px var(--accent-glow);
  }
  .tool-primary__icon {
    width: 74px; height: 74px; border-radius: 20px; flex: 0 0 auto;
    background: linear-gradient(155deg, color-mix(in srgb, var(--accent-ink) 78%, #fff), var(--accent-ink));
    color: #fff; display: flex; align-items: center; justify-content: center;
    box-shadow: 0 14px 28px var(--accent-glow), inset 0 2px 3px rgba(255, 255, 255, 0.45), inset 0 -3px 6px rgba(0, 0, 0, 0.18);
  }
  .tool-primary__text { min-width: 0; }
  .tool-primary__name { display: block; font-family: var(--font-head); font-weight: 800; font-size: clamp(30px, 3.2vw, 42px); letter-spacing: -0.02em; color: var(--ink); line-height: 1; }
  .tool-primary__note { display: inline-block; margin-top: 9px; font-size: 11px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent-ink); }
  .tool-primary__blurb { margin-top: 8px; font-size: 14px; line-height: 1.5; color: var(--body); }

  /* ---- Moving rail ---- */
  .toolrail {
    margin-top: clamp(26px, 3.4vw, 44px);
    width: 100%; overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  .toolrail__track {
    list-style: none; margin: 0; padding: 10px 0; display: flex; width: max-content; gap: 16px;
    animation: tool-marquee 42s linear infinite;
  }
  .toolrail:hover .toolrail__track { animation-play-state: paused; }

  .tile {
    flex: 0 0 auto;
    display: flex; align-items: center; gap: 13px;
    padding: 15px 22px 15px 16px;
    border-radius: 16px;
    background: linear-gradient(155deg, color-mix(in srgb, var(--accent-bg) 70%, var(--surface)), var(--surface));
    border: 1px solid var(--accent-glow);
    box-shadow: 0 12px 26px rgba(64, 90, 180, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.5);
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
  }
  .tile:hover { transform: translateY(-4px); box-shadow: 0 22px 44px rgba(64, 90, 180, 0.18); }
  .tile__icon {
    width: 46px; height: 46px; border-radius: 13px; flex: 0 0 auto;
    background: linear-gradient(155deg, color-mix(in srgb, var(--accent-ink) 72%, #fff), var(--accent-ink));
    color: #fff; display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 16px var(--accent-glow), inset 0 2px 2px rgba(255, 255, 255, 0.5), inset 0 -3px 5px rgba(0, 0, 0, 0.18);
  }
  .tile__name { font-weight: 600; font-size: 14.5px; color: var(--ink); white-space: nowrap; }

  @keyframes tool-marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* Reduced motion: no marquee — a static, centered, wrapping row. */
  @media (prefers-reduced-motion: reduce) {
    .toolrail { -webkit-mask-image: none; mask-image: none; }
    .toolrail__track { animation: none; flex-wrap: wrap; justify-content: center; width: auto; max-width: 1120px; margin-inline: auto; }
    .tile[aria-hidden="true"] { display: none; }
  }

  @media (max-width: 560px) {
    .tool-primary { flex-direction: column; text-align: center; }
    .tool-primary__note { margin-top: 8px; }
  }
</style>
